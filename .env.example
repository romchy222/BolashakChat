# Database Configuration
DATABASE_URL=sqlite:///bolashakbot.db

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-here

# Mistral AI Configuration
MISTRAL_API_KEY=your-mistral-api-key-here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Application Settings
APP_NAME=BolashakBot
APP_VERSION=1.0.0
PORT=5000

# Security Settings (for production)
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# PostgreSQL Configuration (for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/bolashakbot
# PGDATABASE=bolashakbot
# PGHOST=localhost
# PGPORT=5432
# PGUSER=username
# PGPASSWORD=password

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Admin Configuration
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@bolashak.edu.kz

# Upload Settings
MAX_CONTENT_LENGTH=16777216  # 16 MB in bytes
UPLOAD_FOLDER=uploads

# Production Environment Variables (uncomment and set for production)
# FLASK_ENV=production
# FLASK_DEBUG=False
# SESSION_SECRET=your-production-secret-key-at-least-32-characters-long
# SESSION_COOKIE_SECURE=True
# DATABASE_URL=postgresql://user:password@host:port/database
# LOG_LEVEL=WARNING
# LOG_FILE=/app/logs/app.log
